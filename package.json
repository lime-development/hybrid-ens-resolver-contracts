{
  "name": "hybrid-ens-resolver-contracts",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/lime-development/hybrid-ens-resolver-contracts.git"
  },
  "author": "VorobevSA <mail@vorobevsa.com>",
  "license": "MIT",
  "files": [
    "contracts/*.sol",
    "artifacts/contracts/**/*.json"
  ],
  "scripts": {
    "test": "npx mocha",
    "lint": "npx hardhat check",
    "start": "npx hardhat node",
    "build": "npx hardhat compile",
    "compile": "npx hardhat compile",
    "deploy:sepolia": "npx hardhat run scripts/deploy.js --network sepolia",
    "deploy:mainnet": "npx hardhat run scripts/deploy.js --network mainnet",
    "verify:sepolia": "npx hardhat run scripts/verify.js --network sepolia",
    "verify:mainnet": "npx hardhat run scripts/verify.js --network mainnet",
    "prepublishOnly": "yarn build",
    "pub": "yarn publish --access public",
    "clean": "rm -fr node_modules artifacts cache"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^3.0.0",
    "@nomicfoundation/hardhat-ethers": "^4.0.6",
    "@openzeppelin/hardhat-upgrades": "^3.9.1",
    "@nomicfoundation/hardhat-verify": "^3.0.12",
    "chai": "^4.3.10",
    "dotenv": "^17.2.3",
    "ethers": "^6.16.0",
    "hardhat": "^3.2.0",
    "hardhat-deploy": "^2.0.3",
    "mocha": "^11.3.0"
  },
  "dependencies": {
    "@ensdomains/ens-contracts": "^1.6.2",
    "@openzeppelin/contracts": "^5.4.0",
    "@openzeppelin/contracts-upgradeable": "^5.4.0",
    "axios": "^1.13.5"
  },
  "overrides": {
    "qs": "^6.14.1",
    "tmp": "^0.2.4",
    "cookie": "^0.7.0",
    "form-data": "^4.0.4",
    "diff": ">=8.0.3",
    "hardhat-deploy": {
      "axios": "^1.13.2"
    },
    "@ensdomains/ens-contracts": {
      "@openzeppelin/contracts": "^4.9.6"
    },
    "elliptic": "^6.6.1",
    "ws": "^8.18.0",
    "undici": "^6.23.0",
    "minimatch": "^10.2.2",
    "bn.js": "^5.2.3"
  }
}
