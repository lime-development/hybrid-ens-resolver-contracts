SEPOLIA_RPC_URL=https://sepolia.drpc.org
MAINNET_RPC_URL=https://eth.drpc.org

# Deployer private key (must have ETH for gas)
PRIVATE_KEY=your_private_key_here

# Gateway URL(s). Single URL or comma-separated (max 5).
GATEWAY_URL=https://your-gateway-url.com
# GATEWAY_URLS=https://gateway1.com,https://gateway2.com

# CCIP signer addresses (backend keys that sign gateway responses).
# Backend key is stored on the backend server only — never put it here.
SIGNER_ADDRESSES=0xYourBackendSignerAddress1,0xYourBackendSignerAddress2

# setAddr signers: cold keys for onchain setAddr (multisig/hardware).
# Empty value = CCIP-only (no onchain setAddr).
SETADDR_SIGNER_ADDRESSES=0xColdKey1,0xColdKey2
# SETADDR_SIGNER_ADDRESSES=

# Contract owner (e.g. Gnosis Safe or multisig). Required.
OWNER_ADDRESS=0xYourOwnerAddressOrSafe

# Explorer API key (optional, for contract verification)
ETHERSCAN_API_KEY=empty
